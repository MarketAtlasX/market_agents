{
  "openapi": "3.1.0",
  "info": {
    "title": "MarketAtlas Market Data Service",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/snapshot": {
      "post": {
        "summary": "Snapshot",
        "operationId": "snapshot_snapshot_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MarketSnapshotRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarketSnapshot"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "service": {
            "type": "string",
            "title": "Service"
          },
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "degraded"
            ],
            "title": "Status",
            "default": "ok"
          }
        },
        "type": "object",
        "required": [
          "service"
        ],
        "title": "HealthResponse"
      },
      "MarketSnapshot": {
        "properties": {
          "momentum": {
            "type": "number",
            "title": "Momentum"
          },
          "volatility": {
            "type": "number",
            "title": "Volatility"
          },
          "volume": {
            "type": "string",
            "title": "Volume"
          }
        },
        "type": "object",
        "required": [
          "momentum",
          "volatility",
          "volume"
        ],
        "title": "MarketSnapshot"
      },
      "MarketSnapshotRequest": {
        "properties": {
          "prices": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "minItems": 1,
            "title": "Prices"
          },
          "volumes": {
            "anyOf": [
              {
                "items": {
                  "type": "number"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Volumes"
          }
        },
        "type": "object",
        "required": [
          "prices"
        ],
        "title": "MarketSnapshotRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}